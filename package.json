{
  "name": "maple-valley-observatory",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "node scripts/capture-file-times.js && next build",
    "start": "next start",
    "lint": "next lint",
    "capture-timestamps": "node scripts/capture-file-times.js",
    "test": "jest",
    "test:unit": "jest tests/unit --verbose",
    "test:data": "jest tests/data --verbose",
    "test:integration": "jest tests/integration --verbose",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "update-metadata": "node scripts/maintenance/update-metadata.js",
    "precommit": "npm run test && npm run lint",
    "verify": "npm run test && npm run lint && npm run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.1",
    "exifr": "^7.1.3",
    "lucide-react": "^0.536.0",
    "next": "15.4.5",
    "openai": "^5.15.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "shadcn-ui": "^0.9.5",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.4.5",
    "husky": "^9.1.7",
    "jest": "^30.0.5",
    "jest-environment-jsdom": "^30.0.5",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.1",
    "tw-animate-css": "^1.3.6",
    "typescript": "^5"
  }
}
